.env

# Xcode user-specific state (window layout, breakpoints) - not shareable, changes on every launch
xcuserdata/

# Release signing material - never commit
certs/
*.p12

# Local release build output
build/

# Session-scratch planning/analysis docs (code reviews, refactoring plans) and the roadmap/
# mempalace config file - kept locally, deliberately not committed
CODE_REVIEW*.md
REFACTORING_PLAN*.md
ROADMAP.md
WINDOW_SWITCHER_REVIEW.md
mempalace.yaml
